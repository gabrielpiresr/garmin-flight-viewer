# Copie para .env.local e preencha (nunca commite .env.local)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APP_URL=https://app.suaescola.com
VITE_APPWRITE_DATABASE_ID=your_database_id
VITE_APPWRITE_COLLECTION_ID=your_flights_collection_id
VITE_APPWRITE_PROFILES_COLLECTION_ID=your_profiles_collection_id
VITE_APPWRITE_BUCKET_ID=your_bucket_id
VITE_APPWRITE_SYNC_ANAC_FUNCTION_ID=your_sync_anac_function_id
VITE_APPWRITE_ADMIN_USERS_FUNCTION_ID=your_admin_users_function_id
VITE_APPWRITE_SIGN_FLIGHT_FUNCTION_ID=sign-flight

# Vídeos — coleção de metadados de vídeos de voo
VITE_APPWRITE_VIDEOS_COLLECTION_ID=your_flight_videos_collection_id

# Cloudflare R2 via Worker (presigned uploads)
# Deploy workers/video-upload-worker e preencha:
VITE_CF_WORKER_URL=https://video-upload.SEU-SUBDOMINIO.workers.dev
# Segredo do worker fica somente na Appwrite Function admin-users:
# WORKER_SECRET=uma_senha_aleatoria_segura

# Reconciliação — vídeos presos em "processing" (scripts/reconcile-processing-videos.mjs)
# APPWRITE_API_KEY=sua_chave_standard_ou_api_key
# npm run videos:reconcile        # uma vez
# npm run videos:reconcile:watch  # a cada 60s

# Admin — frota e configuração operacional
# Execute: npm run appwrite:setup-admin para criar as coleções e obter os IDs
VITE_SCHOOL_ID=escola_principal
VITE_ADMIN_USER_ID=your_admin_appwrite_user_id
VITE_APPWRITE_AIRCRAFT_MODELS_COL_ID=your_aircraft_models_collection_id
VITE_APPWRITE_AIRCRAFTS_COL_ID=your_aircrafts_collection_id
VITE_APPWRITE_AERODROMES_COL_ID=aerodromes
# Pistas brasileiras com rumos verdadeiros (import: node scripts/import-runways.mjs)
VITE_APPWRITE_RUNWAYS_COL_ID=runways
VITE_APPWRITE_MAINTENANCE_RULES_COL_ID=your_maintenance_rules_collection_id
VITE_APPWRITE_MAINTENANCE_PROGRAM_ITEMS_COL_ID=your_maintenance_program_items_collection_id
VITE_APPWRITE_MAINTENANCE_WORK_ORDERS_COL_ID=your_maintenance_work_orders_collection_id
VITE_APPWRITE_MAINTENANCE_ATTACHMENTS_COL_ID=your_maintenance_attachments_collection_id
VITE_APPWRITE_FUELINGS_COL_ID=aircraft_fuelings
VITE_APPWRITE_OP_WEEKS_COL_ID=your_operational_weeks_collection_id
VITE_APPWRITE_DAILY_CAPS_COL_ID=your_daily_caps_collection_id
VITE_APPWRITE_GROUP_CAPS_COL_ID=your_group_caps_collection_id
VITE_APPWRITE_GROUP_CAP_DAYS_COL_ID=your_group_cap_days_collection_id
VITE_APPWRITE_OP_SLOTS_COL_ID=your_operational_slots_collection_id

# Planejamento semanal de voos (aluno)
# Execute: npm run appwrite:setup-planning para criar as coleções e obter os IDs
VITE_APPWRITE_WEEKLY_PLANS_COL_ID=your_weekly_plans_collection_id
VITE_APPWRITE_WEEKLY_PLAN_ITEMS_COL_ID=your_weekly_plan_items_collection_id
VITE_APPWRITE_WEEKLY_PLAN_AVAIL_COL_ID=your_weekly_plan_avail_collection_id
VITE_APPWRITE_INSTRUCTOR_PREFS_COL_ID=your_instructor_preferences_collection_id

# Créditos do aluno
# Execute: npm run appwrite:setup-credits para criar a coleção
VITE_APPWRITE_STUDENT_CREDITS_COL_ID=your_student_credits_collection_id
# Function cakto-webhook: APPWRITE_STUDENT_CREDITS_COLLECTION_ID
# Function cakto-webhook tambem usa:
# APPWRITE_PROFILES_COLLECTION_ID, APPWRITE_PLATFORM_SETTINGS_COLLECTION_ID
# SAGA_BASE_URL=https://epeac.saga.aero
# SAGA_CREDIT_BANK_ID=6
# SAGA_CREDIT_TYPE=GENERIC
# SAGA_CREDIT_AIRCRAFT_ICAO=MC01

# Financeiro / DRE
VITE_APPWRITE_SCHOOL_COSTS_COL_ID=school_costs
# Function cakto-webhook: APPWRITE_SCHOOL_COSTS_COLLECTION_ID
VITE_APPWRITE_INSTRUCTOR_COSTS_COL_ID=instructor_costs
VITE_APPWRITE_FLIGHT_INSTRUCTOR_PAYMENTS_COL_ID=flight_instructor_payments
VITE_APPWRITE_SCHOOL_PRODUCTS_COL_ID=school_products
VITE_APPWRITE_PRODUCT_SALES_COL_ID=product_sales
# Execute: npm run appwrite:setup-financial-dre para criar as colecoes de fechamento
VITE_APPWRITE_FINANCIAL_MONTHLY_CLOSINGS_COL_ID=financial_monthly_closings
VITE_APPWRITE_FINANCIAL_MONTHLY_CLOSING_LINES_COL_ID=financial_monthly_closing_lines
# Variaveis equivalentes da Appwrite Function admin-users:
# APPWRITE_FINANCIAL_MONTHLY_CLOSINGS_COL_ID=financial_monthly_closings
# APPWRITE_FINANCIAL_MONTHLY_CLOSING_LINES_COL_ID=financial_monthly_closing_lines

# Métricas materializadas de telemetria
# Execute: npm run appwrite:setup-telemetry para criar as coleções
VITE_APPWRITE_FLIGHT_TELEMETRY_SUMMARIES_COL_ID=your_flight_telemetry_summaries_collection_id
VITE_APPWRITE_FLIGHT_LANDINGS_COL_ID=your_flight_landings_collection_id
VITE_APPWRITE_FLIGHT_TAKEOFFS_COL_ID=your_flight_takeoffs_collection_id

# Alertas de telemetria
# Execute: npm run appwrite:setup-telemetry-alerts para criar as coleções
VITE_APPWRITE_TELEMETRY_ALERT_RULES_COL_ID=telemetry_alert_rules
VITE_APPWRITE_FLIGHT_TELEMETRY_ALERTS_COL_ID=flight_telemetry_alerts

# Exercicios avaliados na ficha de voo
# Execute: npm run appwrite:setup-exercises para criar a colecao e importar o catalogo padrao
VITE_APPWRITE_TRAINING_EXERCISES_COL_ID=training_exercises

# Trilhas de treinamento
# Execute: npm run appwrite:setup-tracks para criar as colecoes, importar a trilha padrao e migrar alunos/voos existentes
VITE_APPWRITE_TRAINING_TRACKS_COL_ID=training_tracks
VITE_APPWRITE_STUDENT_TRACKS_COL_ID=student_training_tracks

# Badges e conquistas
# Execute: npm run appwrite:setup-rewards para criar a coleção e importar os 5 badges padrão
VITE_APPWRITE_JOURNEY_REWARDS_COL_ID=journey_rewards

# Feed de avisos
# Execute: npm run appwrite:setup-notices para criar a coleção
VITE_APPWRITE_NOTICES_COL_ID=your_notices_collection_id
# Opcional: bucket dedicado para banners; se vazio, usa VITE_APPWRITE_BUCKET_ID
VITE_APPWRITE_NOTICES_BUCKET_ID=your_notices_banner_bucket_id

# Propostas (CRM)
# Opcional: bucket dedicado das imagens de proposta (diferenciais/seções).
# Se vazio, usa VITE_APPWRITE_BUCKET_ID.
VITE_APPWRITE_PROPOSALS_BUCKET_ID=your_proposals_images_bucket_id

# Central de ajuda
# Execute: npm run appwrite:setup-help-center para criar as colecoes e obter os IDs
VITE_APPWRITE_HELP_SECTIONS_COL_ID=your_help_sections_collection_id
VITE_APPWRITE_HELP_SUBSECTIONS_COL_ID=your_help_subsections_collection_id
VITE_APPWRITE_HELP_ARTICLES_COL_ID=your_help_articles_collection_id
VITE_APPWRITE_HELP_MEDIA_BUCKET_ID=your_help_media_bucket_id

# Notificações por email/push
# Execute: npm run appwrite:setup-notifications para criar as coleções
VITE_APPWRITE_PLATFORM_SETTINGS_COL_ID=your_platform_settings_collection_id

# Onboarding (primeiro acesso do aluno)
# Execute: npm run appwrite:setup-onboarding
VITE_APPWRITE_ONBOARDING_STEPS_COL_ID=your_onboarding_steps_collection_id
VITE_APPWRITE_ONBOARDING_MEDIA_BUCKET_ID=your_onboarding_media_bucket_id
VITE_APPWRITE_PUSH_SUBSCRIPTIONS_COL_ID=your_push_subscriptions_collection_id
VITE_APPWRITE_NOTIFICATION_DELIVERIES_COL_ID=your_notification_deliveries_collection_id
VITE_WEB_PUSH_PUBLIC_KEY=your_vapid_public_key

# CRM e automações de alunos
# Execute: npm run appwrite:setup-student-automations
VITE_APPWRITE_STUDENT_AUTOMATIONS_COL_ID=student_automations
VITE_APPWRITE_AUTOMATION_STATES_COL_ID=student_automation_states
VITE_APPWRITE_AUTOMATION_RUNS_COL_ID=student_automation_runs
VITE_APPWRITE_AUTOMATION_STEP_RUNS_COL_ID=student_automation_step_runs
VITE_APPWRITE_AUTOMATION_JOBS_COL_ID=student_automation_jobs
VITE_APPWRITE_AUTOMATION_EMAIL_TEMPLATES_COL_ID=student_automation_email_templates
VITE_APPWRITE_STUDENT_CRM_STATUSES_COL_ID=student_crm_statuses
VITE_APPWRITE_STUDENT_CRM_PROFILES_COL_ID=student_crm_profiles
SCHOOL_TIMEZONE=America/Sao_Paulo

# Email MKT — segmentos e disparos em massa
# Execute: npm run appwrite:setup-broadcast para criar as coleções
VITE_APPWRITE_BROADCAST_SEGMENTS_COL_ID=your_broadcast_segments_collection_id
VITE_APPWRITE_BROADCAST_MESSAGES_COL_ID=your_broadcast_messages_collection_id

# Assinaturas eletrônicas de voos
# Execute: node scripts/setup-signatures.mjs para criar a coleção
VITE_APPWRITE_FLIGHT_SIGNATURES_COL_ID=flight_signatures
VITE_APPWRITE_LOGBOOK_OPENING_SIGNATURES_COL_ID=logbook_opening_signatures
VITE_APPWRITE_FLIGHT_DISCREPANCIES_COL_ID=flight_discrepancies
# Variáveis da Appwrite Function admin-users (adicionar no console do Appwrite):
# APPWRITE_BROADCAST_SEGMENTS_COLLECTION_ID=<id>
# APPWRITE_BROADCAST_MESSAGES_COLLECTION_ID=<id>
VITE_APPWRITE_SCHEDULE_BOOKING_FUNCTION_ID=schedule-booking
VITE_APPWRITE_CREDIT_ADJUSTMENTS_COL_ID=credit_adjustments
