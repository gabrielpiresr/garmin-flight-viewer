{
  "name": "garmin-flight-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "appwrite:setup": "node scripts/setup-appwrite.mjs",
    "appwrite:migrate:flights": "node scripts/migrate-flight-ownership.mjs",
    "appwrite:set-role": "node scripts/set-user-role.mjs",
